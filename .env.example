# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/raisechat"

# JWT
JWT_SECRET="your-secret-key-change-in-production"

# Backend
PORT=4000

# Frontend（バックエンドAPIのURL）
NEXT_PUBLIC_API_URL="http://localhost:4000"

# CORS（バックエンドが許可するフロントエンドのオリジン）
FRONTEND_URL="http://localhost:3000"

# AWS S3（ファイルアップロード機能）
# ローカル開発: 空のままでも起動可能（S3アップロード機能が無効になる）
# 本番（EC2）: IAMロールを使用するためアクセスキーは不要（空のままでOK）
AWS_REGION="ap-northeast-1"
AWS_S3_BUCKET_NAME="raisechat-attachments"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Sentry（エラートラッキング）
# 未設定の場合 Sentry は無効化されます（起動は止まりません）
SENTRY_DSN=""
SENTRY_RELEASE=""              # オプション: デプロイ時に git SHA 等を設定

# フロントエンド Sentry
NEXT_PUBLIC_SENTRY_DSN=""
