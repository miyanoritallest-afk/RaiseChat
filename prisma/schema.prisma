// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../apps/backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ユーザー
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  displayName   String
  passwordHash  String
  avatarUrl     String?
  status        UserStatus @default(OFFLINE)
  statusMessage String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // リレーション
  workspaceMembers    WorkspaceMember[]
  channelMembers      ChannelMember[]
  messages            Message[]
  reactions           Reaction[]
  pins                Pin[]
  dmRoomMembers       DmRoomMember[]
  dmMessages          DmMessage[]
  notifications       Notification[]
}

enum UserStatus {
  ONLINE
  AWAY
  OFFLINE
}

// ─────────────────────────────────────────────
// ワークスペース
// ─────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  inviteCode  String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // リレーション
  members       WorkspaceMember[]
  channels      Channel[]
  notifications Notification[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // リレーション
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

// ─────────────────────────────────────────────
// チャンネル
// ─────────────────────────────────────────────

model Channel {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // リレーション
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members       ChannelMember[]
  messages      Message[]
  pins          Pin[]
  notifications Notification[]
}

model ChannelMember {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
}

// ─────────────────────────────────────────────
// チャンネルメッセージ
// ─────────────────────────────────────────────

model Message {
  id                    String    @id @default(cuid())
  channelId             String
  userId                String
  content               String
  threadId              String?
  isAlsoPostedToChannel Boolean   @default(false)
  editedAt              DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // リレーション
  channel     Channel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Message?             @relation("ThreadReplies", fields: [threadId], references: [id])
  replies     Message[]            @relation("ThreadReplies")
  attachments MessageAttachment[]
  reactions   Reaction[]
  pins        Pin[]
  notifications Notification[]
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  fileUrl   String
  fileType  FileType
  fileName  String
  fileSize  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Pin {
  id        String   @id @default(cuid())
  messageId String
  channelId String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, channelId])
}

// ─────────────────────────────────────────────
// ダイレクトメッセージ
// ─────────────────────────────────────────────

model DmRoom {
  id        String   @id @default(cuid())
  name      String?
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  members       DmRoomMember[]
  messages      DmMessage[]
  notifications Notification[]
}

model DmRoomMember {
  id        String   @id @default(cuid())
  dmRoomId  String
  userId    String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション
  dmRoom DmRoom @relation(fields: [dmRoomId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dmRoomId, userId])
}

model DmMessage {
  id        String    @id @default(cuid())
  dmRoomId  String
  userId    String
  content   String
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // リレーション
  dmRoom      DmRoom                  @relation(fields: [dmRoomId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments DmMessageAttachment[]
}

model DmMessageAttachment {
  id          String   @id @default(cuid())
  dmMessageId String
  fileUrl     String
  fileType    FileType
  fileName    String
  fileSize    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // リレーション
  dmMessage DmMessage @relation(fields: [dmMessageId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// 通知
// ─────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  messageId   String?
  channelId   String?
  dmRoomId    String?
  workspaceId String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // リレーション
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message?   @relation(fields: [messageId], references: [id], onDelete: SetNull)
  channel   Channel?   @relation(fields: [channelId], references: [id], onDelete: SetNull)
  dmRoom    DmRoom?    @relation(fields: [dmRoomId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────────
// 共通Enum
// ─────────────────────────────────────────────

enum NotificationType {
  MENTION
  UNREAD
  CHANNEL_INVITED
  WORKSPACE_INVITED
  THREAD_REPLY
  REACTION_ADDED
}

enum FileType {
  IMAGE
  VIDEO
}
